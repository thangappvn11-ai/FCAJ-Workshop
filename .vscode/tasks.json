{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Hugo: Run local site",
      "type": "shell",
      "command": "${workspaceFolder}\\.tools\\hugo\\hugo.exe",
      "args": [
        "server",
        "--buildDrafts",
        "--bind",
        "127.0.0.1",
        "--port",
        "1314"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
